# Firebase web config for the Reader extension's Firestore sync.
#
# Setup: copy this file to `.env.local` and fill in the values from the
# Firebase console: Project settings → General → Your apps → (register/select
# a Web app) → "SDK setup and configuration" → Config.
#
# `.env.local` is gitignored. The web apiKey is a project identifier, not a
# secret (it ships in the built client bundle), but keep it out of source and
# restrict it in the Google Cloud Console. Leaving VITE_FIREBASE_API_KEY blank
# keeps cloud sync disabled.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Calendar integration (optional) — see docs/google-calendar-setup.md.
# VITE_CRX_PUBLIC_KEY pins the extension id so it matches your OAuth client
# registration (base64 DER public key → manifest "key"). VITE_GCAL_CLIENT_ID
# is the "Chrome Extension" OAuth client id from Google Cloud Console.
# Leaving either blank keeps the calendar feature disabled.
VITE_CRX_PUBLIC_KEY=
VITE_GCAL_CLIENT_ID=
