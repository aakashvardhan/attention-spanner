# Google Calendar integration (optional) — see docs/google-calendar-setup.md.
# VITE_CRX_PUBLIC_KEY pins the extension id so it matches your OAuth client
# registration (base64 DER public key → manifest "key"). VITE_GCAL_CLIENT_ID
# is the "Chrome Extension" OAuth client id from Google Cloud Console.
# Leaving either blank keeps the calendar feature disabled.
VITE_CRX_PUBLIC_KEY=
VITE_GCAL_CLIENT_ID=
